<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required by Tauri WebView for JavaScript JIT -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Required by Tauri WebView for JIT memory allocation -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Required by Rust compiler for build-time code generation -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <!-- Required for dynamic library loading (sysinfo, windows-rs, etc.) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Network access for system monitoring (TCP/UDP connection enumeration) -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Required for listening port enumeration -->
    <key>com.apple.security.network.server</key>
    <true/>
    <!-- File access for screenshot/save functionality -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <!-- Filesystem monitoring (Phase 5: FsHotspot detection) -->
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
</dict>
</plist>
