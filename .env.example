# Procession Code Signing Configuration
#
# Copy this file to .env and fill in your credentials.
# NOTE: Keep .env out of version control (it's already in .gitignore).
#
# --- Windows Signing ---
# Uses a code signing certificate (PFX). Generate a key pair with:
#   openssl req -x509 -newkey rsa:4096 -keyout procession.key -out procession.crt -days 365 -nodes
#   openssl pkcs12 -export -out procession.pfx -inkey procession.key -in procession.crt
# Then base64-encode the PFX:
#   base64 < procession.pfx
TAURI_SIGNING_PRIVATE_KEY=       # Base64-encoded PFX or PEM private key
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=  # PFX/PEM password
#
# --- macOS Notarization (Apple Developer Account) ---
APPLE_ID=                        # Apple ID email (e.g., developer@example.com)
APPLE_APP_SPECIFIC_PASSWORD=     # App-specific password (generate at appleid.apple.com)
APPLE_TEAM_ID=                   # Team ID (from Apple Developer portal)
APPLE_SIGNING_IDENTITY=          # Developer ID Application certificate name
